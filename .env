# Домен, с которого разрешена регистрация. Через запятую можно указать несколько.
ALLOWED_EMAIL_DOMAINS=evoplay.com

# Контент лендинга
COMPANY_NAME=Evoplay
ANNIVERSARY_YEARS=10
SUPER_PRIZE_TITLE=ДЖЕКПОТ
SUPER_PRIZE_DESCRIPTION=Сьогодні виграють усі — бо 10 років Evoplay це і є наш спільний джекпот. Деталі призу шукай у HR!

# Список стран для выбора (через запятую), "Інша" добавляется автоматически
COUNTRIES=Україна,Польща,Кіпр

# Интересные факты о компании (разделитель "|"). Показываются в карточках секции "Факти про нас".
FUN_FACTS=Понад 500 людей у команді по всьому світу|Наші ігри грають у десятках країн|Цей рік — один з найуспішніших в історії компанії

# Защита от повторного участия по IP (true/false).
# ВНИМАНИЕ: в офисе/VPN сотрудники часто выходят в интернет через один и тот же публичный IP —
# при true после первого участника все остальные с этого IP будут заблокированы.
# Для теста можно временно поставить false, чтобы проверять с одного компьютера.
ENABLE_IP_LOCK=true

PORT=3100

# Секрет для подписи cookie-сессии. Сгенерируй свой перед продом.
COOKIE_SECRET=change-me-in-production
